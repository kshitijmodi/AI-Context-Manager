entrypoint = "main.py"
modules = ["nodejs-20", "python-3.12"]

run = "python3 -m streamlit run main.py --server.port 5000 --server.address 0.0.0.0"

[nix]
channel = "stable-24_05"
packages = ["cargo", "libiconv", "libxcrypt", "rustc"]

[deployment]
run = [
  "sh",
  "-c",
  "python3 -m streamlit run main.py --server.port 5000 --server.address 0.0.0.0",
]

[[ports]]
localPort = 5000
externalPort = 80

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Run App"

[[workflows.workflow]]
name = "Run App"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "streamlit run app.py --server.port 5000 --server.address 0.0.0.0"
waitForPort = 5000
